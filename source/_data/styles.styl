// 自定义样式

// 圆角卡片效果
.post-block {
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  padding: 24px;
  margin-bottom: 24px;
}

// 行内代码样式
code {
  background: rgba(27, 31, 35, 0.05);
  border-radius: 4px;
  padding: 2px 6px;
  font-size: 0.9em;
}

// 暗色模式行内代码
.darkmode {
  code {
    background: rgba(255, 255, 255, 0.1);
  }
}

// 链接悬浮效果
.post-body a:not(.btn) {
  border-bottom: 1px solid #37c6c0;
  &:hover {
    color: #37c6c0;
  }
}

// 引用块美化
blockquote {
  border-left: 4px solid #37c6c0;
  background: rgba(55, 198, 192, 0.05);
  border-radius: 0 8px 8px 0;
  padding: 12px 20px;
}
